diff --git a/Makefile b/Makefile
index 539e4af..481d6b1 100644
--- a/Makefile
+++ b/Makefile
@@ -101,6 +101,7 @@ LIBC_SO     = build/libc/libc.so
 QSH_ELF     = ../quser/build/qsh/qsh.elf
